# Required
TGMGMT_BOT_TOKEN=

# Redis
TGMGMT_REDIS_URL=redis://localhost:6379/0
TGMGMT_REDIS_KEY_PREFIX=tgmgmt

# Loop Prevention
# Deduplication window for identical incoming messages (seconds)
TGMGMT_DEDUP_TTL_SECONDS=5

# Per-(chat,sender_bot) inbound rate limit
TGMGMT_RL_PER_SENDER_RPS=1.0
TGMGMT_RL_PER_SENDER_BURST=3

# Outbound per-(chat,target) rate limit (we throttle ourselves before send)
TGMGMT_RL_OUTBOUND_RPS=1.0
TGMGMT_RL_OUTBOUND_BURST=3

# Global outbound QPS
TGMGMT_RL_GLOBAL_RPS=20
TGMGMT_RL_GLOBAL_BURST=40

# Reply-chain depth: stop replying when depth >= max
TGMGMT_MAX_REPLY_DEPTH=5

# Conversation timeout: a (chat, root) considered closed after N seconds idle
TGMGMT_CONVO_TIMEOUT_SECONDS=60

# Per-bot pair silence timeout: do not respond to same bot more than N times in W seconds
TGMGMT_PAIR_TIMEOUT_SECONDS=30

# Circuit breaker: trip when a bot exceeds X messages within Y seconds in same chat
TGMGMT_CB_THRESHOLD=15
TGMGMT_CB_WINDOW_SECONDS=10
TGMGMT_CB_COOLDOWN_SECONDS=120

# Logging
TGMGMT_LOG_LEVEL=INFO
TGMGMT_AUDIT_LOG_FILE=./audit.log

# Comma-separated bot user_ids that are trusted contributors (may bypass certain limits, never dedup/global)
TGMGMT_TRUSTED_BOT_IDS=

# Comma-separated chat ids the bot is allowed to operate in (empty = all chats it's added to)
TGMGMT_ALLOWED_CHAT_IDS=
